# ════════════════════════════════════════════════════════════════════
# Passive Vigilance — configuration template
#
# SETUP:  cp .env.example .env   then edit .env with your values.
#         The app loads .env (via python-dotenv); this template is never read
#         at runtime — it only documents every supported setting.
#
# SECRETS:  Values marked "SECRET — treat as a password" below are
#           credentials. Put real secrets ONLY in .env, never in this file.
#           .env is git-ignored; .env.example is committed. Never commit a
#           real secret, and never move credentials out of .env.
#
# CONTRIBUTORS:  When you add a new os.getenv("…") to the code, add the
#                matching slot here so this template stays complete.
# ════════════════════════════════════════════════════════════════════

# Session output
SESSION_OUTPUT_DIR=data/sessions
# NOTE: SESSION_NAME is not currently read by the code (reserved/unused).
SESSION_NAME=

# Logging
LOG_LEVEL=INFO

# WiGLE API credentials
# WIGLE_API_NAME is the API token *name* (not secret); WIGLE_API_KEY is SECRET — treat as a password.
WIGLE_API_NAME=
WIGLE_API_KEY=
# adsb.lol / ADSBExchange API key — SECRET, treat as a password.
# Get free API key by feeding to adsb.lol: https://www.adsb.lol/docs/
ADSBXLOL_API_KEY=your-adsb-lol-api-key-here

ALERT_BACKEND=ntfy
# Ntfy settings (https://ntfy.sh or self-hosted)
# NTFY_TOPIC is effectively a shared secret — anyone who knows it can read your alerts. Treat as a password.
NTFY_TOPIC=your-unique-topic-name-here
NTFY_SERVER=https://ntfy.sh
# Telegram settings (optional) — TELEGRAM_BOT_TOKEN is SECRET, treat as a password.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Discord settings (optional) — DISCORD_WEBHOOK_URL is SECRET (anyone with it can post). Treat as a password.
DISCORD_WEBHOOK_URL=
# Alert rate limiting
DRONE_ALERT_COOLDOWN_SECONDS=600
PERSISTENCE_ALERT_COOLDOWN_SECONDS=300
AIRCRAFT_ALERT_COOLDOWN_SECONDS=60
# NOTE: RATE_LIMIT_REMOTE_ID is not currently read by the code (reserved/unused).
RATE_LIMIT_REMOTE_ID=300

# USB WiFi dongle interface name — set automatically by install.sh
# Verify with: iw dev
WIFI_MONITOR_INTERFACE=wlan1

# GPS device
GPS_DEVICE=/dev/ttyUSB0
# How long to wait for initial GPS fix at startup (seconds)
GPS_STARTUP_TIMEOUT_SECONDS=120
# GPS fix quality filtering
GPS_MIN_QUALITY=2d
GPS_MAX_HDOP=5.0
# GPS_MIN_QUALITY options: any, 2d, 3d
# GPS_MAX_HDOP: reject fixes with horizontal dilution > this value
# Lower is better — 1.0=excellent, 2.0=good, 5.0=moderate

# Kismet REST API
KISMET_HOST=localhost
KISMET_PORT=2501
# Generate in Kismet web UI: http://[pi-ip]:2501
# Settings -> API Keys -> Create API Key -> name: passive-vigilance
# KISMET_API_KEY is SECRET — treat as a password.
KISMET_API_KEY=your-kismet-api-key-here

# dump1090 SBS-1 (BaseStation) output
# NOTE: DUMP1090_HOST is read by the code; DUMP1090_PORT is informational only —
# the ADS-B module connects via READSB_URL (HTTP 8080), not the SBS-1 port.
DUMP1090_HOST=localhost
DUMP1090_PORT=30003

# readsb JSON HTTP endpoint — override if serving on a non-default port or path
# Default matches tar1090's alternate-port config patched by install.sh to 8080
READSB_URL=http://localhost:8080/data/aircraft.json

# Set false to disable the DroneRF scanner entirely (readsb keeps the dongle
# full-time for ADS-B; no SDR time-share). Use this if the RTL-SDR scan path is
# unstable on your hardware (see issue #63 — native libusb SIGSEGV).
DRONE_RF_ENABLED=true
# Drone RF detection power threshold in dB (signals above this trigger alerts)
DRONE_POWER_THRESHOLD_DB=-20
# Drone RF duty cycle — prevent thermal throttling on Pi
# NOTE: DRONE_RF_SCAN_SECONDS is not currently read by the code (reserved/unused);
# the duty cycle is driven by DRONE_RF_REST_SECONDS only.
DRONE_RF_SCAN_SECONDS=10
DRONE_RF_REST_SECONDS=20
# Set DRONE_RF_REST_SECONDS=0 to disable duty cycle (continuous scan)
# Recommended on Pi 3B+: rest 20, on Pi 4B+: rest 10
DRONE_RF_MAX_TEMP_C=75

# RTL-SDR sharing mode — controls how one dongle is shared between readsb (ADS-B)
# and DroneRF when only one RTL-SDR is present.
#   auto      — detect dongle count at startup; DEDICATED if ≥2, SHARED if 1
#   shared    — force time-share (single dongle alternates between ADS-B and drone scan)
#   dedicated — force simultaneous mode (requires two RTL-SDR dongles)
SDR_MODE=auto
# Time-slice lengths for SHARED mode (seconds each)
ADSB_SLICE_SECONDS=30
DRONE_RF_SLICE_SECONDS=30

# ── Detection mode (REQUIRED — no code default) ─────────────────────
# NODE_MODE selects the scoring strategy. The node REFUSES to start if this is
# unset/invalid and no --mode flag is given (design 2.1, fail loud).
#   mobile = location-diversity scoring — "does this device follow me?"
#            (wardriving / on-person / vehicle). The existing, default behavior.
#   fixed  = baseline-deviation scoring — "what deviates from this location's
#            normal?" (stationary base station / leave-behind).
# .env NODE_MODE takes precedence over the --mode CLI flag.
NODE_MODE=mobile

# Fixed mode only — length of the baseline learning window in hours. After this
# many hours from first start the baseline freezes and novel devices are flagged.
# Persisted across restarts (a crash loop does NOT reset the window). Default 72.
FIXED_BASELINE_HOURS=72

# Fixed mode only — absolute path to the durable baseline SQLite DB. Leave blank
# to use <repo>/data/baseline.db (gitignored). Set an absolute path to override.
BASELINE_DB_PATH=

# Fixed mode only — off-schedule (a known device seen in an unusual hour-of-day)
# does not activate until a device's baseline spans at least this many DISTINCT
# hours, so a thin baseline can't false-alarm on every hour rollover. Default 12.
OFF_SCHEDULE_MIN_BASELINE_HOURS=12

# Persistence engine — counter-surveillance scoring
PERSISTENCE_ALERT_THRESHOLD=0.7
PERSISTENCE_MIN_LOCATIONS=2
PERSISTENCE_POLL_INTERVAL_SECONDS=30

# MAC randomization handling
# Detect and fingerprint randomized MACs (iOS 14+, Android 10+, Windows 10+)
HANDLE_MAC_RANDOMIZATION=true
# Set true to silently drop all randomized MACs from tracking (reduces noise)
IGNORE_RANDOMIZED_MACS=false
# Score thresholds:
# 0.5-0.7 = suspicious, 0.7-0.9 = likely surveillance, 0.9+ = high confidence

# Sensor poll intervals (seconds)
GPS_POLL_INTERVAL_SECONDS=1
ADSB_POLL_INTERVAL_SECONDS=5
KISMET_POLL_INTERVAL_SECONDS=30
DRONE_POLL_INTERVAL_SECONDS=5
REMOTE_ID_POLL_INTERVAL_SECONDS=5

# Operational resilience
# How often to log the 5-minute health banner (seconds)
HEALTH_BANNER_INTERVAL_SECONDS=300
# How many times to attempt reconnect before giving up
MAX_RECONNECT_ATTEMPTS=3
# Seconds to wait between reconnect attempts
RECONNECT_INTERVAL_SECONDS=5

# Stall watchdog
# Seconds a poll loop may go without COMPLETING before it is marked degraded
# (catches a hung/dead task). Liveness only — an idle sensor is not flagged.
SENSOR_STALL_SECONDS=180
# Seconds a data sensor's loop may keep completing while its cumulative counter
# stays frozen before capture is declared dead (catches a silent upstream freeze).
SENSOR_DATA_STALL_SECONDS=600
# Which sensors get the data-progress (frozen-counter) check. Comma-separated.
# kismet re-reports its device set every poll so its counter always climbs; an
# empty sky makes ADS-B legitimately flat, so adsb is off by default.
WATCHDOG_DATA_SENSORS=kismet
# How often the dedicated watchdog task evaluates stalls and beats systemd.
WATCHDOG_INTERVAL_SECONDS=30
# Self-restart crash-guard: stop self-restarting after this many restarts within
# the window, so a persistent root cause cannot become a restart loop.
WATCHDOG_MAX_RESTARTS=5
WATCHDOG_RESTART_WINDOW_S=1800

# ── Web GUI (optional) ──────────────────────────────────────────────
# Set GUI_ENABLED=true to start the web dashboard
# Access at http://[pi-ip]:8080 or via Tailscale
# Requires: pip install flask (included in requirements.txt)
GUI_ENABLED=false
GUI_PORT=8080
GUI_HOST=0.0.0.0
# Optional bearer token to restrict dashboard access. SECRET — treat as a password.
# When set, requests must include: Authorization: Bearer <token>
# or append ?token=<token> to the URL. Leave empty for open access.
GUI_TOKEN=
