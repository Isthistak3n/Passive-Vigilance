# Session output
SESSION_OUTPUT_DIR=data/sessions
SESSION_NAME=

# Logging
LOG_LEVEL=INFO

# WiGLE API credentials
WIGLE_API_NAME=
WIGLE_API_KEY=

# adsb.lol / ADSBExchange API key
# Get free API key by feeding to adsb.lol: https://www.adsb.lol/docs/
ADSBXLOL_API_KEY=your-adsb-lol-api-key-here

ALERT_BACKEND=ntfy
# Ntfy settings (https://ntfy.sh or self-hosted)
NTFY_TOPIC=your-unique-topic-name-here
NTFY_SERVER=https://ntfy.sh
# Telegram settings (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Discord settings (optional)
DISCORD_WEBHOOK_URL=
# Alert rate limiting
DRONE_ALERT_COOLDOWN_SECONDS=600
PERSISTENCE_ALERT_COOLDOWN_SECONDS=300
AIRCRAFT_ALERT_COOLDOWN_SECONDS=60

# USB WiFi dongle interface name — set automatically by install.sh
# Verify with: iw dev
WIFI_MONITOR_INTERFACE=wlan1

# GPS device
GPS_DEVICE=/dev/ttyUSB0

# Kismet REST API
KISMET_HOST=localhost
KISMET_PORT=2501
# Generate in Kismet web UI: http://[pi-ip]:2501
# Settings -> API Keys -> Create API Key -> name: passive-vigilance
KISMET_API_KEY=your-kismet-api-key-here

# dump1090 SBS-1 (BaseStation) output
DUMP1090_HOST=localhost
DUMP1090_PORT=30003

# Drone RF detection power threshold in dB (signals above this trigger alerts)
DRONE_POWER_THRESHOLD_DB=-20

# Persistence engine — counter-surveillance scoring
PERSISTENCE_ALERT_THRESHOLD=0.7
PERSISTENCE_MIN_LOCATIONS=2
PERSISTENCE_POLL_INTERVAL_SECONDS=30
# Score thresholds:
# 0.5-0.7 = suspicious, 0.7-0.9 = likely surveillance, 0.9+ = high confidence
