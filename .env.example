# ════════════════════════════════════════════════════════════════════
# Passive Vigilance — configuration template
#
# SETUP:  cp .env.example .env   then edit .env with your values.
#         The app loads .env (via python-dotenv); this template is never read
#         at runtime — it only documents every supported setting.
#
# SECRETS:  Values marked "SECRET — treat as a password" below are
#           credentials. Put real secrets ONLY in .env, never in this file.
#           .env is git-ignored; .env.example is committed. Never commit a
#           real secret, and never move credentials out of .env.
#
# CONTRIBUTORS:  When you add a new os.getenv("…") to the code, add the
#                matching slot here so this template stays complete.
# ════════════════════════════════════════════════════════════════════

# Session output
SESSION_OUTPUT_DIR=data/sessions
# NOTE: SESSION_NAME is not currently read by the code (reserved/unused).
SESSION_NAME=

# Logging
LOG_LEVEL=INFO

# WiGLE API credentials
# WIGLE_API_NAME is the API token *name* (not secret); WIGLE_API_KEY is SECRET — treat as a password.
WIGLE_API_NAME=
WIGLE_API_KEY=
# adsb.lol / ADSBExchange API key — SECRET, treat as a password.
# Get free API key by feeding to adsb.lol: https://www.adsb.lol/docs/
ADSBXLOL_API_KEY=your-adsb-lol-api-key-here

ALERT_BACKEND=ntfy
# Ntfy settings (https://ntfy.sh or self-hosted)
# NTFY_TOPIC is effectively a shared secret — anyone who knows it can read your alerts. Treat as a password.
NTFY_TOPIC=your-unique-topic-name-here
NTFY_SERVER=https://ntfy.sh
# Telegram settings (optional) — TELEGRAM_BOT_TOKEN is SECRET, treat as a password.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Discord settings (optional) — DISCORD_WEBHOOK_URL is SECRET (anyone with it can post). Treat as a password.
DISCORD_WEBHOOK_URL=
# Alert rate limiting
DRONE_ALERT_COOLDOWN_SECONDS=600
PERSISTENCE_ALERT_COOLDOWN_SECONDS=300
AIRCRAFT_ALERT_COOLDOWN_SECONDS=60
# NOTE: RATE_LIMIT_REMOTE_ID is not currently read by the code (reserved/unused).
# Alert sends run off the event loop on a single worker thread; if a slow/unreachable
# backend backs up this many sends in flight, further alerts are dropped (counted) rather
# than queued unboundedly — so a misconfigured backend can never stall capture/scoring.
ALERT_MAX_INFLIGHT=32
RATE_LIMIT_REMOTE_ID=300

# USB WiFi dongle interface name — set automatically by install.sh
# Verify with: iw dev
WIFI_MONITOR_INTERFACE=wlan1

# GPS device
GPS_DEVICE=/dev/ttyUSB0
# How long to wait for initial GPS fix at startup (seconds)
GPS_STARTUP_TIMEOUT_SECONDS=120
# GPS fix quality filtering
GPS_MIN_QUALITY=2d
GPS_MAX_HDOP=5.0
# GPS_MIN_QUALITY options: any, 2d, 3d
# GPS_MAX_HDOP: reject fixes with horizontal dilution > this value
# Lower is better — 1.0=excellent, 2.0=good, 5.0=moderate

# Kismet REST API
KISMET_HOST=localhost
KISMET_PORT=2501
# Generate in Kismet web UI: http://[pi-ip]:2501
# Settings -> API Keys -> Create API Key -> name: passive-vigilance
# KISMET_API_KEY is SECRET — treat as a password.
KISMET_API_KEY=your-kismet-api-key-here
# Startup connect retry: Kismet's REST API accepts connections a few seconds after
# its service reports "active", so on a cold boot the first connect can race it.
# PV retries KISMET_CONNECT_RETRIES times, KISMET_CONNECT_RETRY_INTERVAL_SECONDS
# apart (defaults 15 x 5s = ~70s window) before disabling WiFi/BT for the session.
KISMET_CONNECT_RETRIES=15
KISMET_CONNECT_RETRY_INTERVAL_SECONDS=5

# dump1090 SBS-1 (BaseStation) output
# NOTE: DUMP1090_HOST is read by the code; DUMP1090_PORT is informational only —
# the ADS-B module connects via READSB_URL (HTTP 8080), not the SBS-1 port.
DUMP1090_HOST=localhost
DUMP1090_PORT=30003

# readsb JSON HTTP endpoint — override if serving on a non-default port or path.
# Default matches tar1090's alternate-port config patched by install.sh to 8080.
# GOTCHA: a stock tar1090 install (lighttpd 88-tar1090.conf) instead serves the JSON
# at  http://localhost/tar1090/data/aircraft.json  on port 80 — the /data/ alias only
# exists in the :8504 "otherport" config, which may not be listening. If the dashboard
# shows 0 aircraft while tar1090 shows traffic, confirm this URL returns JSON (curl it)
# and set it to the path your lighttpd actually serves.
READSB_URL=http://localhost:8080/data/aircraft.json

# DroneRF is RETIRED — replaced by the AIS/ADS-B(/ACARS) decode cycle below. The
# code is kept for reversibility but DEFAULTS OFF (low-value power-threshold scans,
# antenna-limited at 2.4/5.8 GHz, and the libusb SIGSEGV of issue #63). Leave false
# unless you specifically want the legacy scanner back in the SDR cycle.
DRONE_RF_ENABLED=false

# Passive BLE advertisement capture. When true, Passive Vigilance owns the BT
# dongle (hci0) directly via a raw HCI socket and listens (no transmitting) for
# advertisements, feeding them through the same fingerprint/scoring/GUI path as
# WiFi — this is what makes randomized-MAC BLE devices fingerprintable. Requires:
#   1. exclusive use of hci0 — REMOVE Kismet's linuxbluetooth source from
#      /etc/kismet/kismet_site.conf (the two cannot share the controller), and
#   2. CAP_NET_RAW + CAP_NET_ADMIN, granted by the systemd unit's
#      AmbientCapabilities (already in deploy/passive-vigilance.service).
# Default false so nodes that keep Kismet for Bluetooth are unaffected.
BLE_SCANNER_ENABLED=false
# Which HCI controller the BLE scanner binds. Leave blank to auto-detect the
# lowest-numbered controller present (handles a dongle that re-enumerates to hci1
# after a USB reset). Set e.g. hci1 to pin a specific controller.
BLE_HCI_DEVICE=
# Drone RF detection power threshold in dB (signals above this trigger alerts)
DRONE_POWER_THRESHOLD_DB=-20
# Drone RF duty cycle — prevent thermal throttling on Pi
# NOTE: DRONE_RF_SCAN_SECONDS is not currently read by the code (reserved/unused);
# the duty cycle is driven by DRONE_RF_REST_SECONDS only.
DRONE_RF_SCAN_SECONDS=10
DRONE_RF_REST_SECONDS=20
# Set DRONE_RF_REST_SECONDS=0 to disable duty cycle (continuous scan)
# Recommended on Pi 3B+: rest 20, on Pi 4B+: rest 10
DRONE_RF_MAX_TEMP_C=75

# RTL-SDR sharing mode — how the dongle(s) are used across bands.
#   auto      — detect dongle count at startup; DEDICATED if ≥2, SHARED if 1
#   shared    — force time-share (single dongle cycles across bands, below)
#   dedicated — force simultaneous mode (each band its own dongle; ≥2 RTL-SDRs)
SDR_MODE=auto
# Default per-band slice lengths for the SHARED cycle (seconds).
ADSB_SLICE_SECONDS=840
DRONE_RF_SLICE_SECONDS=30

# ── AIS (marine vessel tracking, VHF ~162 MHz) ─────────────────────────────
# OPTIONAL / best-effort. AIS will NOT receive on a 1090 MHz ADS-B antenna and
# degrades inland, so it is OFF by default. Needs the AIS-catcher decoder
# (INSTALL_AIS=true ./deploy/install.sh). When enabled on a SINGLE dongle, the SDR
# coordinator time-shares: ADS-B for the bulk of a ~15-min cycle, then a short AIS
# slice — during which ADS-B is briefly blind (a second VHF dongle in DEDICATED mode
# removes that blackout). The decoder emits JSON over UDP to the listener below.
AIS_ENABLED=false
AIS_SLICE_SECONDS=60
AIS_UDP_HOST=127.0.0.1
AIS_UDP_PORT=10110
AIS_POLL_INTERVAL_SECONDS=10
# systemd unit name the coordinator starts/stops (must match the sudoers scope).
AIS_SERVICE=ais-catcher
# Drop AIS contacts farther than this (km) from the node's GPS fix — AIS is VHF
# (line-of-sight), so an implausibly distant vessel is a misdecode (noise that
# passed CRC). GPS-gated: with no fix, no filtering. 0 disables the filter.
AIS_MAX_RANGE_KM=100

# Explicit SDR time-share cycle — overrides the auto-derived one. Ordered
# "band:seconds" list; bands: adsb, ais, drone_rf. Example 15-min cycle:
#   SDR_CYCLE_SLICES=adsb:840,ais:60
# Leave blank to auto-derive from the enabled bands (ADS-B only → no time-share).
# (ACARS is NOT a cycle slice — it's preemption-driven; see below.)
SDR_CYCLE_SLICES=

# ── ACARS (aviation VHF datalink, ~131 MHz) ────────────────────────────────
# OPTIONAL / best-effort, OFF by default (VHF — won't receive on a 1090 antenna).
# ACARS is PLAINTEXT (decoded, not "decrypted") and a SHARED broadcast: you receive
# every aircraft and correlate by tail/flight-id. Needs the acarsdec decoder
# (INSTALL_ACARS=true ./deploy/install.sh). On a SINGLE dongle it's preemption-driven:
# when an ADS-B contact has been held continuously past ACARS_TRIGGER_SECONDS, the
# coordinator gives ACARS the dongle for ACARS_WINDOW_SECONDS (during which ADS-B is
# briefly blind), then resumes. A 2nd VHF dongle (DEDICATED) runs ACARS continuously.
ACARS_ENABLED=false
ACARS_TRIGGER_SECONDS=30
ACARS_WINDOW_SECONDS=25
ACARS_MAX_WINDOWS_PER_CYCLE=4
ACARS_UDP_HOST=127.0.0.1
ACARS_UDP_PORT=5555
ACARS_POLL_INTERVAL_SECONDS=5
ACARS_SERVICE=acarsdec
# When a decoded message carries a position but its tail/callsign match no live
# contact, it binds to the nearest ADS-B contact within this many km (a position
# report and the ADS-B fix can be minutes apart, so allow some slack).
ACARS_POSITION_MATCH_KM=50

# ACARS↔ADS-B correlation needs the contact's registration (ICAO→tail). Connectivity-
# adaptive: adsb.lol enrichment when ADSBXLOL_API_KEY is set (online), else a local
# offline DB. Build the offline DB OFF-NODE and copy it on (opsec — no node-side
# queries):  python3 scripts/build_aircraft_registry.py --out aircraft.sqlite
AIRCRAFT_REGISTRY_DB=data/registry/aircraft.sqlite

# ── Detection mode (REQUIRED — no code default) ─────────────────────
# NODE_MODE selects the scoring strategy. The node REFUSES to start if this is
# unset/invalid and no --mode flag is given (design 2.1, fail loud).
#   mobile = location-diversity scoring — "does this device follow me?"
#            (wardriving / on-person / vehicle). The existing, default behavior.
#   fixed  = baseline-deviation scoring — "what deviates from this location's
#            normal?" (stationary base station / leave-behind).
# .env NODE_MODE takes precedence over the --mode CLI flag.
NODE_MODE=mobile

# Fixed mode only — length of the baseline learning window in hours. After this
# many hours from first start the baseline freezes and novel devices are flagged.
# Persisted across restarts (a crash loop does NOT reset the window). Default 72.
FIXED_BASELINE_HOURS=72

# Fixed mode only — absolute path to the durable baseline SQLite DB. Leave blank
# to use <repo>/data/baseline.db (gitignored). Set an absolute path to override.
BASELINE_DB_PATH=

# Fixed mode only — off-schedule (a known device seen in an unusual hour-of-day)
# does not activate until a device's baseline spans at least this many DISTINCT
# hours, so a thin baseline can't false-alarm on every hour rollover. Default 12.
OFF_SCHEDULE_MIN_BASELINE_HOURS=12

# Fixed mode only — egregious-during-baseline safety net (design 5.2). Even while
# learning, a device physically in the operator's space (very strong signal) pages
# so an already-present threat isn't baked into "normal". RSSI is negative dBm; a
# device at or ABOVE the threshold (less negative = closer) flags. These page even
# though a single egregious signal scores 0.5 (below the WiFi paging bar).
#
# NODE_DENSITY picks the Wi-Fi threshold preset: dense=-30, suburban=-40, rural=-50.
# A dense node needs a stricter (closer) bar or it floods on nearby traffic.
NODE_DENSITY=suburban
# Explicit Wi-Fi egregious threshold (dBm) — overrides the NODE_DENSITY preset.
# EGREGIOUS_SIGNAL_DBM=-40
# BLE egregious threshold (dBm) — SEPARATE from Wi-Fi because BLE RSSI runs much
# lower and is inherently short-range. Default -50. May need calibration against
# the operator's own device if it advertises at low TX power (e.g. iPhones).
# EGREGIOUS_BLE_SIGNAL_DBM=-50

# Persistence engine — counter-surveillance scoring
PERSISTENCE_ALERT_THRESHOLD=0.7
PERSISTENCE_MIN_LOCATIONS=2
PERSISTENCE_POLL_INTERVAL_SECONDS=30

# MAC randomization handling
# Detect and fingerprint randomized MACs (iOS 14+, Android 10+, Windows 10+)
HANDLE_MAC_RANDOMIZATION=true
# Set true to silently drop all randomized MACs from tracking (reduces noise)
IGNORE_RANDOMIZED_MACS=false
# AP-beacon capture + network affinity: record which probed SSIDs are also being
# beaconed locally (a rotation-surviving "belongs here" signal). Pure capture, no
# scoring effect; set false to skip the beacon_evidence / network_affinity writes.
BEACON_CAPTURE_ENABLED=true
# Contact identity tiers (DISPLAY only — never changes what fires an alert). A device
# is keyed for its persistent contact by an SSID-anchored fingerprint so it re-links
# across MAC rotation / return. FP_DISTINCTIVE_MAX_DF is the STRONG bar (anchor SSID
# probed by ≤ this many distinct devices); FP_MEDIUM_MAX_DF is a looser bar for a
# MEDIUM ("likely same") tier that catches more devices at some over-merge risk.
FP_DISTINCTIVE_MAX_DF=3
FP_MEDIUM_MAX_DF=12
# A WiFi/BT contact re-seen after an absence longer than this (seconds) is flagged a
# RETURN (like a returning aircraft) instead of a new contact.
WIFI_RETURN_GAP_SECONDS=900
# Cap on the in-memory per-contact return-tracking table (distinct identities).
CONTACT_TRACK_MAX=20000
# Cross-session "returning entity" (P4-B): a contact identity is remembered across
# restarts/days in the durable store. On reappearing in a NEW session it is flagged
# "seen before" only if the prior sighting was at least this many seconds ago (or on a
# different UTC day) — so a quick crash-restart isn't mistaken for a return visit.
ENTITY_RETURN_MIN_GAP_SECONDS=3600
#
# ── entities.db size bounding (keep the poll loop off the systemd watchdog) ──
# The entity/observation store (data/entities.db) records every poll for cross-session
# identity. Only its observation history grows; these bound it so it can't balloon to
# the multi-GB size that stalls SQLite on the SD card and crash-loops the node.
# Age window: delete observations older than this many days (0 = keep forever).
ENTITY_OBSERVATION_RETENTION_DAYS=30
# Hard row ceiling, enforced independently of the age window: once the observations
# table exceeds this, the OLDEST rows beyond it are pruned regardless of age. The age
# window alone deletes nothing for its whole span, so on a busy node the file grows
# unchecked for weeks first; this cap gives a real near-term plateau. 0 = uncapped.
ENTITY_OBSERVATION_MAX_ROWS=4000000
# WAL truncation cadence (seconds). WAL mode only auto-checkpoints in PASSIVE mode,
# which a busy writer on slow storage starves — the WAL then grows without bound (a
# ~1 GB WAL made every startup replay it and stall). This periodically folds the WAL
# back into the DB and resets it to zero. 0 = disable (rely on SQLite auto-checkpoint).
ENTITY_WAL_CHECKPOINT_SECONDS=300
# Retention-sweep bounds (advanced): rows per DELETE and the wall-clock budget per
# sweep, so a big backlog drains across sweeps instead of blocking the loop at once.
ENTITY_PRUNE_INTERVAL_SECONDS=3600
ENTITY_PRUNE_BATCH_ROWS=5000
ENTITY_PRUNE_TIME_BUDGET_S=1.0
# Off-loop writer (EXPERIMENTAL, default off). When true, each poll's entity write is
# handed to a dedicated writer thread with its own DB connection instead of running on
# the asyncio poll loop, so even a multi-second SD fsync can't stall the loop past the
# watchdog. Reads stay on the main connection. Under sustained storage backpressure a
# poll's observations are dropped rather than blocking capture. File DB only (ignored
# for :memory:). Validate on-node before trusting it in the field.
ENTITY_ASYNC_WRITES=false
# Max queued polls before the off-loop writer starts dropping (only used when the
# writer is enabled). A full queue means storage can't keep up with the poll rate.
ENTITY_WRITE_QUEUE_MAX=240
# Cross-PHY co-presence linking (P4-C): group a person's MOBILE radios (Wi-Fi client +
# BLE) that travel together into one "person"; APs are excluded (they're the fixed
# environment). Conservative — a device only joins a person on strong co-presence, so a
# phone with no wearable stays a single contact. Display/awareness only, no phone page.
CROSS_PHY_LINKING_ENABLED=true
COPRESENCE_MIN_POLLS=12          # a pair must be co-present in at least this many polls
COPRESENCE_MIN_JACCARD=0.7       # shared/union of their present-polls must exceed this
COPRESENCE_FIXTURE_FRACTION=0.5  # present in more than this fraction of polls = a fixture
COPRESENCE_MIN_OBS_POLLS=6       # each contact must be seen at least this many polls
COPRESENCE_MIN_FIXTURE_POLLS=30  # fixture gate is dormant below this many total polls
# Resident-vs-visitor: a persistent VISITOR (novel, no local-network affinity) raises a
# display-only Alerts-feed entry once it has lingered at least this many observations.
VISITOR_ALERT_MIN_OBS=20
# Score thresholds:
# 0.5-0.7 = suspicious, 0.7-0.9 = likely surveillance, 0.9+ = high confidence

# Sensor poll intervals (seconds)
GPS_POLL_INTERVAL_SECONDS=1
ADSB_POLL_INTERVAL_SECONDS=5
KISMET_POLL_INTERVAL_SECONDS=30
DRONE_POLL_INTERVAL_SECONDS=5
REMOTE_ID_POLL_INTERVAL_SECONDS=5

# Operational resilience
# How often to log the 5-minute health banner (seconds)
HEALTH_BANNER_INTERVAL_SECONDS=300
# How many times to attempt reconnect before giving up
MAX_RECONNECT_ATTEMPTS=3
# Seconds to wait between reconnect attempts
RECONNECT_INTERVAL_SECONDS=5

# Stall watchdog
# Seconds a poll loop may go without COMPLETING before it is marked degraded
# (catches a hung/dead task). Liveness only — an idle sensor is not flagged.
SENSOR_STALL_SECONDS=180
# Seconds a data sensor's loop may keep completing while its cumulative counter
# stays frozen before capture is declared dead (catches a silent upstream freeze).
SENSOR_DATA_STALL_SECONDS=600
# Which sensors get the data-progress (frozen-counter) check. Comma-separated.
# kismet re-reports its device set every poll so its counter always climbs; an
# empty sky makes ADS-B legitimately flat, so adsb is off by default.
WATCHDOG_DATA_SENSORS=kismet
# How often the dedicated watchdog task evaluates stalls and beats systemd.
WATCHDOG_INTERVAL_SECONDS=30
# Self-restart crash-guard: stop self-restarting after this many restarts within
# the window, so a persistent root cause cannot become a restart loop.
WATCHDOG_MAX_RESTARTS=5
WATCHDOG_RESTART_WINDOW_S=1800

# ── Web GUI (optional) ──────────────────────────────────────────────
# Set GUI_ENABLED=true to start the web dashboard
# Access at http://[pi-ip]:8080 or via Tailscale
# Requires: pip install flask (included in requirements.txt)
GUI_ENABLED=false
GUI_PORT=8080
GUI_HOST=0.0.0.0
# Optional bearer token to restrict dashboard access. SECRET — treat as a password.
# When set, requests must include: Authorization: Bearer <token>
# or append ?token=<token> to the URL. Leave empty for open access.
# NOTE: this token ALSO unlocks THIS node's own survey/patrol control endpoints
# (/api/patrol, /api/tasking, /api/survey) — they hard-refuse when GUI_TOKEN is
# empty. A mobile node must set GUI_TOKEN to start/end a patrol from its own GUI or
# via curl. Do not confuse it with SURVEY_TOKEN below (that is the *fixed* node's
# token, used to reach the fixed node during sync).
GUI_TOKEN=

# ── Rolling-baseline adaptation (fixed mode, P3) ────────────────────
# Post-freeze, promote consistently-present devices into the baseline (stop reading
# novel) and demote long-absent ones — the durable fix for novelty fatigue over days.
# off (default/fail-safe) = baseline frozen forever. conservative = slow-in (5 days)
# fast-out (24h). permissive = faster (3 days). Per-knob overrides: ADAPT_PROMO_MIN_DAYS,
# ADAPT_PROMO_MIN_SPAN_HOURS, ADAPT_PROMO_MIN_DISTINCT_HOURS, ADAPT_DEMOTE_AFTER_HOURS.
ADAPTATION_POSTURE=off

# ── Reconnaissance pair: survey taskings + offload (design §5.5) ─────
# Turns a fixed + mobile node into a hunter/recon pair: the FIXED node flags a
# suspicious device and issues a survey tasking; the MOBILE node roams, records
# where that device beds down (long dwell / repeat visits / overnight), and offloads
# the findings back. Master switch — off by default (zero overhead: no DB, no sync).
SURVEY_ENABLED=false
# SurveyStore SQLite path (taskings + observations + findings).
SURVEY_DB_PATH=data/survey.db
# This node's id, stamped on taskings/findings. Defaults to the hostname if unset.
SURVEY_NODE_ID=
#
# ── Fixed-node knobs ──
# Auto-enroll a high-severity, strongly-fingerprinted contact as a survey target
# without an operator tapping "Task survey". Off by default — the operator button is
# the primary path (a mac:-only contact is never surveyable and is refused).
SURVEY_AUTOTASK=off
# Severity bar for auto-tasking: suspicious | likely | high.
SURVEY_AUTOTASK_MIN_LEVEL=high
#
# ── Mobile-node knobs ──
# Base URL of the FIXED node's GUI server. Set this (and the token) to make a mobile
# node participate; empty = the node runs as a plain mobile node (no sync task).
SURVEY_FIXED_URL=
# The FIXED node's GUI_TOKEN (Bearer), used by THIS mobile node to call the fixed
# node's survey endpoints during sync (pull taskings / push findings). This is NOT
# what authorizes this node's own local /api/patrol etc. — that is this node's own
# GUI_TOKEN above. A participating mobile node needs BOTH set: its own GUI_TOKEN
# (local control) and SURVEY_TOKEN (the fixed node's token, for sync).
SURVEY_TOKEN=
# How often (seconds) the mobile node pulls taskings + pushes findings when the fixed
# node is reachable. Store-and-forward: an unreachable base node just retries.
SURVEY_SYNC_INTERVAL_SECONDS=120
# Bed-down is resolved by AP ASSOCIATION first: if a local AP beaconing the tasked
# device's distinctive home network is heard, its location is the residence (one
# patrol, no dwell needed). After this many patrol polls with NO device sighting AND
# no home AP found, the task reports "not located" (a WiGLE candidate) rather than
# staying silent — so a device that was simply never encountered is surfaced.
SURVEY_MIN_PATROL_POLLS=20
# Operator-bounded patrol backstop (hours): a patrol left running past this is
# auto-ended so a forgotten "end patrol" can't hold tasks open forever (design §10).
SURVEY_PATROL_MAX_HOURS=12
# Wardrive index (design §11): while a patrol runs, every AP heard is banked (deduped
# by BSSID) so a bed-down resolves by querying the index for a task's anchor SSID —
# retroactively, even for a device tasked after the walk, and a patrol with no tasking
# still maps the area. Node-local, never committed. Retention (days); 0 = keep forever.
SURVEY_WARDRIVE_RETENTION_DAYS=90
# Spatial clustering radius (metres) for grouping survey sightings into a location.
SURVEY_CLUSTER_METERS=100
# Survey-observation history retention (days); 0 = keep forever.
SURVEY_OBS_RETENTION_DAYS=30
# Local-time "overnight" window (HH-HH, wraps midnight) + the visit-gap that bounds
# dwell — these annotate a device's own sightings with confidence when several
# accumulate (secondary to the AP-association bed-down, not the primary signal).
SURVEY_NIGHT_HOURS=22-06
SURVEY_VISIT_GAP_SECONDS=600
#
# ── Fixed-node display: distance bands from the node ──
# The FIXED node's position is the reference for classifying where a device was found
# (a GUI-pinned AIR_HOME_LAT/LON wins, else the live GPS fix). Within IMMEDIATE = where
# the node already sees it (not new); within NEIGHBORHOOD = elsewhere in the local area
# (resident there); beyond = distant.
SURVEY_IMMEDIATE_METERS=150
SURVEY_NEIGHBORHOOD_METERS=3000
